{
  "name": "n8n-nodes-hostinger-api",
  "version": "1.0.21",
  "description": "Hostinger API n8n Node",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://hostinger.com",
  "author": {
    "name": "Hostinger",
    "email": "minijus.savickas@hostinger.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hostinger/api-n8n-node.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/HostingerApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/hostingerApi/HostingerApi.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.0",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "overrides": {
    "uuid": ">=14.0.0",
    "n8n-workflow": {
      "form-data": "^4.0.4",
      "lodash": "^4.17.23"
    },
    "eslint-plugin-n8n-nodes-base": {
      "minimatch": "9.0.9"
    },
    "release-it": {
      "undici": "6.24.1"
    },
    "flatted": "3.4.2",
    "langsmith": "0.5.19",
    "@langchain/community": "1.1.24"
  }
}
